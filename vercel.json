{
  "version": 2,
  "functions": {
    "api/manychat-report.ts": { "maxDuration": 10 },
    "api/refresh-report-cache.ts": { "maxDuration": 60 },
    "api/launch-data.ts": { "maxDuration": 30 },
    "api/meta-spend.ts": { "maxDuration": 30 },
    "api/dashboard-data.ts": { "maxDuration": 60 },
    "api/meta-ads-data.ts": { "maxDuration": 60 },
    "api/send-daily-report.ts": { "maxDuration": 30 }
  },
  "crons": [
    {
      "path": "/api/send-daily-report",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/refresh-report-cache",
      "schedule": "*/15 * * * *"
    }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}

